{
  "mcpServers": {
    "jira-daily-pm-radar": {
      "command": "<path_to_uv_exe>",
      "args": [
        "run",
        "--directory",
        "<PROJECT_DIR>",
        "--extra",
        "mcp",
        "jira-radar-mcp"
      ],
      "env": {
        "JIRA_BASE_URL": "<YOUR_JIRA_URL>",
        "JIRA_EMAIL": "<YOUR_JIRA_EMAIL>",
        "JIRA_API_TOKEN": "<YOUR_JIRA_API_TOKEN>"
      }
    }
  }
}
