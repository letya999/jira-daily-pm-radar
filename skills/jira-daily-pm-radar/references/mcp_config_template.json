{
  "mcpServers": {
    "jira-daily-pm-radar": {
      "command": "uvx",
      "args": [
        "--from",
        "git+https://github.com/letya999/jira-daily-pm-radar.git[mcp]",
        "jira-radar-mcp"
      ],
      "env": {
        "JIRA_BASE_URL": "<YOUR_JIRA_URL>",
        "JIRA_EMAIL": "<YOUR_JIRA_EMAIL>",
        "JIRA_API_TOKEN": "<YOUR_JIRA_API_TOKEN>"
      }
    }
  }
}
