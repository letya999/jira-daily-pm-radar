# Copy to .env and fill real values locally. Never commit .env.

# Jira Cloud example: https://your-domain.atlassian.net
JIRA_BASE_URL=

# Jira Cloud basic auth: email + API token
JIRA_EMAIL=
JIRA_API_TOKEN=

# Optional bearer token alternative for Jira Server/Data Center setups
JIRA_BEARER_TOKEN=

# Optional defaults
JIRA_DEFAULT_PROJECT=DEMO
JIRA_DEFAULT_BOARD_ID=
JIRA_RADAR_TIMEZONE=Asia/Almaty
JIRA_RADAR_OUTPUT_DIR=reports
